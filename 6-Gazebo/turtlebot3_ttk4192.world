    <!-- Vertical wall x=5.21, from y=1.8 to y=2.55 -->
    <model name="wall_int_7">
      <static>true</static>
      <pose>5.21 2.175 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 0.75 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.75 0.5</size></box></geometry>
          <material><script><name>Gazebo/Grey</name></script></material>
