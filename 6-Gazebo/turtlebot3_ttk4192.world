    </model>

    <!-- Vertical wall x=3.6, from y=0 to y=1.8 -->
    <model name="wall_int_6">
      <static>true</static>
      <pose>3.6 0.9 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 1.8 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 1.8 0.5</size></box></geometry>
          <material><script><name>Gazebo/Grey</name></script></material>
