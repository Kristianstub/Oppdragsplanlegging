<?xml version="1.0" ?>
<sdf version="1.5">
  <world name="default">

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Outer walls -->
    <!-- Bottom wall -->
    <model name="wall_bottom">
      <static>true</static>
      <pose>4.25 0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>8.5 0.05 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>8.5 0.05 0.5</size></box></geometry>
          <material><script><name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Top wall -->
    <model name="wall_top">
      <static>true</static>
      <pose>4.25 2.55 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>8.5 0.05 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>8.5 0.05 0.5</size></box></geometry>
          <material><script><name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Left wall -->
    <model name="wall_left">
      <static>true</static>
      <pose>0 1.275 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 2.55 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 2.55 0.5</size></box></geometry>
          <material><script><name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Right wall -->
    <model name="wall_right">
      <static>true</static>
      <pose>8.5 1.275 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 2.55 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 2.55 0.5</size></box></geometry>
          <material><script><name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Interior walls based on Fig. 7 -->

    <!-- Vertical wall x=1.2, from y=0 to y=1.0 -->
    <model name="wall_int_1">
      <static>true</static>
      <pose>1.2 0.5 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 1.0 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 1.0 0.5</size></box></geometry>
          <material><script><name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Vertical wall x=1.2, from y=1.4 to y=2.55 -->
    <model name="wall_int_2">
      <static>true</static>
      <pose>1.2 1.975 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 1.15 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 1.15 0.5</size></box></geometry>
          <material><script><name>Gazebo/Grey</name></script></material>
        </visual>
