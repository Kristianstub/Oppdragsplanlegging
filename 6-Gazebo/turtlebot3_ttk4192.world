    </model>

    <!-- Horizontal wall y=1.8, from x=3.6 to x=5.21 -->
    <model name="wall_int_8">
      <static>true</static>
      <pose>4.405 1.8 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
